/.infra-docs.bundle

# ── OS / 에디터 노이즈 ──
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
*~
.vscode/
.idea/
*.sublime-*

# ── Python ──
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/
*.egg-info/

# ── Node ──
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── 비밀값 (루트에 절대 커밋 금지) ──
.env
.env.*
!.env.example
*.key
*.pem
*.p12
*.pfx
secrets/
credentials.json

# ── 빌드 산출물 ──
